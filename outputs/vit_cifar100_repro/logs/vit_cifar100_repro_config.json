{
  "seed": 42,
  "experiment_name": "vit_cifar100_repro",
  "output_dir": "outputs/vit_cifar100_repro",
  "dataset": {
    "name": "cifar100",
    "data_dir": "./data",
    "image_size": 32,
    "val_split": 0.1,
    "batch_size": 512,
    "num_workers": 8
  },
  "model": {
    "type": "vit",
    "image_size": 32,
    "patch_size": 4,
    "embed_dim": 192,
    "depth": 8,
    "num_heads": 3,
    "mlp_ratio": 4.0,
    "dropout": 0.1,
    "attention_dropout": 0.1,
    "drop_path_rate": 0.1
  },
  "train": {
    "epochs": 100,
    "lr": 0.0005,
    "weight_decay": 0.05,
    "betas": [
      0.9,
      0.999
    ],
    "warmup_epochs": 5,
    "min_lr_ratio": 0.01,
    "label_smoothing": 0.1,
    "grad_clip": 1.0,
    "use_amp": true,
    "mixup_alpha": 0.1,
    "save_every": 10
  },
  "eval": {
    "topk": [
      1,
      5
    ]
  }
}